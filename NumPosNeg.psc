//Verificar si es un positivo
//negativo
Algoritmo NumPosNeg
	//Entradas 
	Escribir "===NUNEROS NEGARIVOS Y POSITIVOS==="
	Definir num Como Entero
	Escribir "Dame un numero entero: "
	Leer num
	
	Si num> 0 Entonces
		Escribir "es un numero positivo"
	SiNo
		Escribir "es un numero negativo"
		
	Fin Si
	
FinAlgoritmo
